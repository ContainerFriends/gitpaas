generator client {
  provider = "prisma-client-js"
  output   = "./src/core/infrastructure/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model SystemConfig {
  id            String    @id @db.Uuid
  traceId       String    @unique @map("trace_id")
  appId         String    @unique @map("app_id")
  privateKey    String    @map("private_key") @db.Text
  webhookSecret String    @map("webhook_secret")
  appSlug       String    @map("app_slug")
  initializedAt DateTime  @map("initialized_at")
  installedAt   DateTime? @map("installed_at")

  @@map("system_configs")
}
