generator client {
  provider = "prisma-client-js"
  output   = "../../.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        String   @id
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("projects")
}