generator client {
  provider = "prisma-client-js"
  output   = "../../apps/backend/src/core/infrastructure/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        String   @id
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  services Service[]

  @@map("projects")
}

model Service {
  id              String      @id
  name            String
  type            ServiceType @default(docker_compose)
  gitProviderId   String?     @map("git_provider_id")
  repositoryId    String?     @map("repository_id")
  branch          String?     @default("main")
  composePath     String?     @map("compose_path")
  projectId       String      @map("project_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  gitProvider GitProvider? @relation(fields: [gitProviderId], references: [id])

  @@map("services")
}

enum ServiceType {
  docker_compose

  @@map("service_type")
}

enum GitProviderType {
  github
}

enum GitProviderStatus {
  pending
  active
  error
}

model GitProvider {
  id           String            @id
  name         String
  type         GitProviderType   @default(github)
  status       GitProviderStatus @default(pending)
  externalId   String            @map("external_id")
  slug         String
  traceId      String            @unique @map("trace_id")
  privateKey     String            @map("private_key")
  clientId       String            @map("client_id")
  clientSecret   String            @map("client_secret")
  installationId String?           @map("installation_id")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  services Service[]

  @@map("git_providers")
}