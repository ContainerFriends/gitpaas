{
  "name": "gitpaas",
  "version": "1.3.6",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup:local": "./scripts/local-development.sh",
    "clean:local": "./scripts/clean-local-environment.sh",
    "dev:backend": "npm run dev --workspace=@gitpaas/backend",
    "dev:github-installer": "npm run dev --workspace=@gitpaas/github-installer",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean"
  },
  "dependencies": {
    "date-fns": "4.1.0",
    "dockerode": "4.0.9"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "semantic-release": "25.0.3",
    "turbo": "2.8.17",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": "24.14.0",
    "npm": "11.9.0"
  }
}
