{
  "name": "gitpaas",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "npm run setup --workspace=@gitpaas/setup",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean"
  },
  "dependencies": {
     "date-fns": "4.1.0",
    "dockerode": "4.0.9"
  },
  "devDependencies": {
    "@types/dockerode": "4.0.1",
    "@types/node": "25.3.5",
    "turbo": "2.8.14",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": "24.14.0",
    "npm": "11.9.0"
  }
}