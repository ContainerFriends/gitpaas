{
  "name": "deploy-hub",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "gitpaas:setup": "tsx -r dotenv/config setup.ts && sleep 5 && npm run migration:run",
    "migration:run": "tsx -r dotenv/config migration.ts",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:frontend": "turbo run dev --filter=@deploy-hub/frontend",
    "dev:backend": "turbo run dev --filter=@deploy-hub/backend",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@types/node": "25.3.5",
    "turbo": "2.8.14",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": "24.14.0",
    "npm": "11.9.0"
  }
}