#Environment
NODE_ENV=development

# Traefik configuration
TRAEFIK_SSL_PORT=443
TRAEFIK_PORT=80
TRAEFIK_HTTP3_PORT=443
TRAEFIK_VERSION="3.6.10"

# GitPaaS configuration
GITPAAS_PORT=3000

# Redis configuration
REDIS_IMAGE="redis:8.4-alpine3.22"

# Postgres configuration
POSTGRES_IMAGE="postgres:18.3-alpine3.23"

# Database configuration
DATABASE_URL="postgres://gitpaas:password@localhost:5432/gitpaas"
PRISMA_SCHEMA_PATH="../../iac/database/schema.prisma"
PRISMA_MIGRATIONS_PATH="../../iac/database/migrations"
