{
  "name": "@gitpaas/setup",
  "version": "0.0.0",
  "description": "GitPaaS installation and configuration management",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "setup": "tsx -r dotenv/config main.ts && sleep 5 && pnpm run migration:run",
    "migration:run": "tsx -r dotenv/config migration.ts"
  },
  "dependencies": {
    "bl": "4.1.0",
    "dockerode": "4.0.9"
  },
  "devDependencies": {
    "@gitpaas/eslint-config": "*",
    "@types/bl": "5.0.2",
    "@types/dockerode": "4.0.1"
  }
}
