{
  "name": "@gitpaas/setup",
  "version": "0.0.0",
  "description": "GitPaaS installation and configuration management",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "setup": "tsx -r dotenv/config src/main.ts && sleep 5 && npm run prisma:generate && npm run prisma:migrate",
    "prisma:generate": "prisma generate --config=./prisma.config.ts",
    "prisma:migrate": "prisma migrate deploy --config=./prisma.config.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "bl": "6.1.6",
    "dockerode": "4.0.9",
    "dotenv": "17.3.1",
    "pg": "8.20.0",
    "prisma": "7.4.2",
    "yaml": "2.8.2"
  },
  "devDependencies": {
    "@gitpaas/eslint-config": "*",
    "@types/bl": "5.0.2",
    "@types/dockerode": "4.0.1",
    "@types/pg": "8.18.0"
  }
}
