{
  "name": "@gitpaas/setup",
  "version": "0.0.0",
  "private": true,
  "description": "GitPaaS installation and configuration management",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./installer": "./dist/installer.js",
