{
  "name": "@gitpaas/setup",
  "version": "0.0.0",
  "description": "GitPaaS installation and configuration management for local development and production",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "setup:local": "tsx -r dotenv/config src/main.ts local",
    "setup:production": "tsx src/main.ts production",
    "build": "tsc",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.4.2",
    "@prisma/client": "7.4.2",
    "bl": "6.1.6",
    "dockerode": "4.0.9",
    "dotenv": "17.3.1",
    "pg": "8.20.0",
    "prisma": "7.4.2",
    "yaml": "2.8.2"
  },
  "devDependencies": {
    "@gitpaas/eslint-config": "*",
    "@types/bl": "5.0.2",
    "@types/dockerode": "4.0.1",
    "@types/pg": "8.18.0"
  }
}
