{
  "name": "@gitpaas/setup",
  "version": "0.0.0",
  "description": "GitPaaS installation and configuration management",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "setup": "tsx -r dotenv/config src/setup.ts && sleep 5 && pnpm run migration:run",
    "migration:run": "tsx -r dotenv/config src/migration.ts"
  },
  "dependencies": {
    "@prisma/client": "7.4.2",
    "bl": "6.1.6",
    "dockerode": "4.0.9",
    "prisma": "7.4.2",
    "yaml": "2.8.2"
  },
  "devDependencies": {
    "@gitpaas/eslint-config": "*",
    "@types/bl": "5.0.2",
    "@types/dockerode": "4.0.1"
  }
}
